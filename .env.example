# 服务器监听配置
PORT=5005
HOST=0.0.0.0

# 可选 API Key 认证（留空 = 局域网信任模式）
API_KEY=

# 超时配置（秒）
STT_TIMEOUT=60
LLM_TIMEOUT=30

# ============================================================
# 火山引擎 STT
# ============================================================
VOLC_APP_ID=
VOLC_ACCESS_TOKEN=

# ============================================================
# 大模型（doubao 或 minimax）
# ============================================================
LLM_PROVIDER=doubao

# 豆包
ARK_API_KEY=
ARK_MODEL=doubao-seed-2-0-lite-260215
ARK_BASE_URL=https://ark.cn-beijing.volces.com/api/v3/chat/completions

# MiniMax（使用 minimax 时填写）
MINIMAX_API_KEY=
MINIMAX_MODEL=abab6.5s-chat
MINIMAX_BASE_URL=https://api.minimax.chat/v1/text/chatcompletion_v2

# ============================================================
# 飞书
# ============================================================
FEISHU_APP_ID=
FEISHU_APP_SECRET=

# 默认发送目标（可留空，运行后在 /admin 页面配置）
FEISHU_RECEIVE_ID=
AT_USER_ID=
